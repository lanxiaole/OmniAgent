# OmniAgent 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ==================== 通义千问 API Key ====================
# 必填，用于 LLM 和 Embedding
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== OpenAI 兼容 API Key（可选） ====================
# 可选，如果你想使用其他 OpenAI 兼容的 API 服务
# 获取地址：https://bailian.console.aliyun.com/cn-beijing#/home
OPENAI_API_KEY=your_openai_api_key_here

# ==================== 高德地图 API Key（可选） ====================
# 可选，用于天气查询功能
# 获取地址：https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here
